{
  "name": "@alexendros/protonmail-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.Alexendros/protonmail-mcp",
  "description": "MCP server for Proton Mail via Proton Mail Bridge (IMAP/SMTP). Dual transport: stdio + streamable HTTP.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "protonmail-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iniciativas-Alexendros/protonmail-mcp.git"
  },
  "homepage": "https://github.com/Iniciativas-Alexendros/protonmail-mcp#readme",
  "bugs": {
    "url": "https://github.com/Iniciativas-Alexendros/protonmail-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proton-mail",
    "proton-bridge",
    "imap",
    "smtp",
    "anthropic",
    "claude"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "imapflow": "^1.0.189",
    "mailparser": "^3.7.2",
    "nodemailer": "^8.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
